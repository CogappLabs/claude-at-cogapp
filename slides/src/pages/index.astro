---
import { getCollection } from "astro:content";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { slideOrder } from "../content/order";

const all = await getCollection("slides");
const bySlug = new Map(all.map((s) => [s.id, s]));
const ordered = slideOrder.map((slug, i) => {
  const s = bySlug.get(slug);
  if (!s) throw new Error(`Order references missing slide: ${slug}`);
  return { ...s, order: i + 1 };
});
const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Claude Code at Cogapp</title>
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <link rel="alternate icon" href={`${BASE}/favicon.ico`} />
    <link rel="preload" href={`${BASE}/fonts/civil/CivilPremium-Regular2.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${BASE}/fonts/civil/CivilPremium-Medium2.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${BASE}/fonts/untitled-serif/untitled-serif-regular.woff2`} as="font" type="font/woff2" crossorigin />
    <ClientRouter />
  </head>
  <body class="bg-cream text-slate m-0">
    <main class="max-w-[1100px] mx-auto px-12 py-20">
      <header class="mb-20">
        <p class="font-sans font-medium text-sm uppercase tracking-[0.1em] opacity-60 mb-2">
          A developer's guide
        </p>
        <h1 class="font-serif text-5xl md:text-7xl lg:text-8xl leading-none tracking-tight mb-8">
          Claude Code <em class="italic text-grey">at</em> Cogapp.
        </h1>
        <a
          href={`${BASE}/slide/${slideOrder[0]}`}
          class="inline-block font-sans text-lg font-medium text-slate bg-pink px-8 py-4 rounded-full no-underline transition-transform hover:-translate-y-0.5"
        >
          Start →
        </a>
      </header>

      <ol class="list-none p-0 m-0 columns-1 md:columns-2 gap-12">
        {ordered.map((s) => (
          <li class="break-inside-avoid mb-2">
            <a
              href={`${BASE}/slide/${s.id}`}
              class="grid grid-cols-[2.5em_1fr_auto] gap-4 items-baseline py-2 text-slate no-underline border-b border-slate/10 transition-colors hover:bg-pink"
            >
              <span class="font-mono text-xs opacity-50 tabular-nums">
                {String(s.order).padStart(2, "0")}
              </span>
              <span class="font-serif text-lg">{s.data.title}</span>
              {s.data.section && (
                <span class="font-sans text-xs uppercase tracking-[0.08em] opacity-50">
                  {s.data.section}
                </span>
              )}
            </a>
          </li>
        ))}
      </ol>
    </main>
  </body>
</html>
