---
interface Props {
  bg?: "cream" | "slate" | "pink" | "green" | "purple" | "blue" | "white";
  align?: "start" | "center" | "end";
}
const { bg = "cream", align = "center" } = Astro.props;
const bgMap: Record<string, string> = {
  cream: "var(--cream)",
  slate: "var(--slate)",
  pink: "var(--accent-pink)",
  green: "var(--accent-green)",
  purple: "var(--accent-purple)",
  blue: "var(--accent-blue)",
  white: "var(--white)",
};
const fg = bg === "slate" ? "var(--cream)" : "var(--slate)";
---

<section
  class="slide"
  data-slide
  style={`background:${bgMap[bg]};color:${fg};justify-content:${align};`}
>
  <div class="slide-inner">
    <slot />
  </div>
</section>

<style>
  .slide {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    padding: var(--space-20) var(--space-12);
    scroll-snap-align: start;
  }
  .slide-inner {
    max-width: 1100px;
    width: 100%;
    margin: 0 auto;
  }
  .slide :global(h1) {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    margin: 0 0 var(--space-8);
    letter-spacing: -0.01em;
  }
  .slide :global(h2) {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1.1;
    margin: 0 0 var(--space-6);
  }
  .slide :global(h3) {
    font-size: clamp(1.5rem, 2.5vw, 2rem);
    margin: 0 0 var(--space-4);
  }
  .slide :global(p),
  .slide :global(li) {
    font-size: clamp(1.1rem, 1.6vw, 1.4rem);
    margin: 0 0 var(--space-4);
  }
  .slide :global(ul),
  .slide :global(ol) {
    padding-left: var(--space-8);
  }
  .slide :global(table) {
    border-collapse: collapse;
    width: 100%;
    font-size: clamp(0.95rem, 1.3vw, 1.15rem);
  }
  .slide :global(th),
  .slide :global(td) {
    border-bottom: 1px solid currentColor;
    padding: var(--space-2) var(--space-4);
    text-align: left;
  }
  .slide :global(blockquote) {
    border-left: 4px solid currentColor;
    padding-left: var(--space-6);
    margin: 0 0 var(--space-6);
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.3rem, 2vw, 1.7rem);
    line-height: 1.3;
  }
  .slide :global(pre.astro-code) {
    background: var(--slate) !important;
    color: var(--cream);
    padding: var(--space-4) var(--space-6);
    border-radius: 6px;
    font-size: clamp(0.85rem, 1.05vw, 1rem);
    line-height: 1.55;
  }
  .slide :global(:not(pre) > code) {
    background: rgba(40, 40, 40, 0.08);
    color: inherit;
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }
</style>
