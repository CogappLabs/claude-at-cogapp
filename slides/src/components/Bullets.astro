---
interface Props {
  size?: "md" | "lg";
}
const { size = "md" } = Astro.props;
const sizeClass =
  size === "lg"
    ? "[&_li]:text-[clamp(1.3rem,2vw,1.7rem)]"
    : "[&_li]:text-[clamp(1.1rem,1.6vw,1.4rem)]";
---

<ul
  role="list"
  class:list={[
    "bullets list-none p-0 m-0 mb-6",
    "[&_li]:relative [&_li]:pl-8 [&_li]:mb-4 [&_li]:leading-snug",
    "[&_li]:before:content-[''] [&_li]:before:absolute [&_li]:before:left-0 [&_li]:before:top-[0.7em] [&_li]:before:w-[18px] [&_li]:before:h-px [&_li]:before:bg-current [&_li]:before:opacity-60",
    sizeClass,
  ]}
>
  <slot />
</ul>
